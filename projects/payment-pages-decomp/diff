+func TestTruncateErrorMessage(t *testing.T) {
+	t.Run("empty string returns unknown_error", func(t *testing.T) {
+		result := truncateErrorMessage("")
+		assert.Equal(t, "unknown_error", result)
+	})
+
+	t.Run("short message returns as is", func(t *testing.T) {
+		result := truncateErrorMessage("validation_failure: type: cannot be blank.")
+		assert.Equal(t, "validation_failure: type: cannot be blank.", result)
+	})
+
+	t.Run("message at max length returns as is", func(t *testing.T) {
+		msg := "a"
+		for len(msg) < MaxErrorMessageLength {
+			msg += "a"
+		}
+		result := truncateErrorMessage(msg)
+		assert.Equal(t, MaxErrorMessageLength, len(result))
+	})
+
+	t.Run("long message is truncated", func(t *testing.T) {
+		msg := "This is a very long error message that exceeds the maximum allowed length for metrics labels to prevent high cardinality issues in Prometheus"
+		result := truncateErrorMessage(msg)
+		assert.Equal(t, MaxErrorMessageLength, len(result))
+		assert.Equal(t, msg[:MaxErrorMessageLength], result)
+	})
+}
