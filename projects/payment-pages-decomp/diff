+					now := time.Now().Unix()
+					if now > endsBy {
+						shouldReject = true
+					}
+				}
+			}
+		}
+
+		assert.False(t, shouldReject, "Future timestamp with is_active=1 should be allowed")
+	})
+
+	t.Run("nil is_active should not trigger timestamp validation", func(t *testing.T) {
+		pastTimestamp := time.Now().Unix() - 3600
+
+		gt := &nocode.GoalTracker{
+			IsActive: nil, // nil is_active
