+		responseItems := []models.PaymentPageItem{
+			{ID: "ppi_33333333333333", Item: nil},
+		}
+
+		requestItems := []nocode.MonolithPaymentPageItem{} // Empty request
+
+		err := EmbedMonolithItemIdsInCreateItemRequests(ctx, "pl_test", responseItems, &requestItems)
+
+		require.Nil(t, err, "empty request should not cause error")
+	})
+
+	t.Run("mixed_valid_and_nil_items_matched_correctly", func(t *testing.T) {
+		// Test that valid items are matched correctly even with nil items interspersed
+		responseItems := []models.PaymentPageItem{
+			{ID: "ppi_44444444444444", Item: nil},
+			{
+				ID: "ppi_55555555555555",
+				Item: &models.Item{
+					ID:     "item_5555555555555a",
+					Name:   "Item One",
+					Amount: uint64Ptr(100),
+				},
+			},
+			{ID: "ppi_66666666666666", Item: nil},
+			{
+				ID: "ppi_77777777777777",
+				Item: &models.Item{
+					ID:     "item_7777777777777a",
+					Name:   "Item Two",
+					Amount: uint64Ptr(200),
+				},
+			},
+		}
+
+		name1 := "Item One"
+		name2 := "Item Two"
