+// TestIsStringZero_EdgeCases tests edge cases and boundary conditions
+func TestIsStringZero_EdgeCases(t *testing.T) {
+	t.Run("whitespace in string is invalid", func(t *testing.T) {
+		var nv NumericUInt64Value
+		err := json.Unmarshal([]byte(`" 0"`), &nv)
+		assert.Error(t, err) // " 0" is not a valid number
+	})
+
+	t.Run("leading zeros in string", func(t *testing.T) {
+		var nv NumericUInt64Value
+		err := json.Unmarshal([]byte(`"000"`), &nv)
+		assert.NoError(t, err)
+		assert.Equal(t, uint64(0), nv.Value)
+		assert.False(t, nv.IsStringZero(), "Only exact '0' should be flagged")
+	})
+
+	t.Run("string with leading zeros and value", func(t *testing.T) {
+		var nv NumericUInt64Value
+		err := json.Unmarshal([]byte(`"0100"`), &nv)
+		assert.NoError(t, err)
+		assert.Equal(t, uint64(100), nv.Value)
+		assert.False(t, nv.IsStringZero())
+	})
+
+	t.Run("max uint32 value (mysql_unsigned_int limit)", func(t *testing.T) {
+		var nv NumericUInt64Value
+		err := json.Unmarshal([]byte(`"4294967295"`), &nv)
+		assert.NoError(t, err)
+		assert.Equal(t, uint64(4294967295), nv.Value)
+		assert.False(t, nv.IsStringZero())
+	})
