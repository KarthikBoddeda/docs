+	// Fallback: try to extract from response body
+	responseBody := ncaResponse.GetResponseBody()
+	if responseBody == nil {
+		return "unknown_error"
+	}
+
+	bodyMap, ok := responseBody.(map[string]interface{})
+	if !ok {
+		return "unknown_error"
+	}
+
+	return extractDescriptionFromErrorMap(bodyMap)
