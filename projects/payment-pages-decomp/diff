+// TestIsStringZero_ValidationIntegration tests how IsStringZero should be used in validation
+func TestIsStringZero_ValidationIntegration(t *testing.T) {
+	// This simulates the ValidateEmptyStringForIntegerFields logic
+	validateField := func(field *NumericUInt64Value, fieldName string) error {
+		if field != nil && field.IsStringZero() {
+			return assert.AnError // Simulating validation error
+		}
+		return nil
+	}
+
+	t.Run("validation passes for integer 0", func(t *testing.T) {
+		var nv NumericUInt64Value
+		_ = json.Unmarshal([]byte(`0`), &nv)
+		err := validateField(&nv, "min_amount")
+		assert.NoError(t, err)
+	})
+
+	t.Run("validation fails for string \"0\"", func(t *testing.T) {
+		var nv NumericUInt64Value
+		_ = json.Unmarshal([]byte(`"0"`), &nv)
+		err := validateField(&nv, "min_amount")
+		assert.Error(t, err)
+	})
+
+	t.Run("validation passes for nil", func(t *testing.T) {
+		var nv *NumericUInt64Value = nil
+		err := validateField(nv, "min_amount")
+		assert.NoError(t, err)
+	})
+
+	t.Run("validation passes for non-zero string", func(t *testing.T) {
+		var nv NumericUInt64Value
+		_ = json.Unmarshal([]byte(`"100"`), &nv)
+		err := validateField(&nv, "min_amount")
+		assert.NoError(t, err)
+	})
+}
