+func TestCountMismatchWithNilItems(t *testing.T) {
+	ctx := setupTestContext()
+
+	amountReqPtr := func(v uint64) *datatypes.NumericUInt64Value {
+		return &datatypes.NumericUInt64Value{Value: v}
+	}
+
+	t.Run("request_count_exceeds_effective_response_count", func(t *testing.T) {
+		// 3 request items, 2 response items (1 nil) = 1 effective
+		// Should fail because 3 > 1
+		responseItems := []models.PaymentPageItem{
+			{
+				ID: "ppi_88888888888888",
+				Item: &models.Item{
+					ID:     "item_888888888888a8",
+					Name:   "Valid",
+					Amount: uint64Ptr(100),
+				},
+			},
+			{ID: "ppi_99999999999999", Item: nil},
+		}
+
+		name := "Valid"
+		requestItems := []nocode.MonolithPaymentPageItem{
+			{Item: &nocode.MonolithItem{Name: &name, Amount: amountReqPtr(100)}},
+			{Item: &nocode.MonolithItem{Name: &name, Amount: amountReqPtr(100)}},
+			{Item: &nocode.MonolithItem{Name: &name, Amount: amountReqPtr(100)}},
+		}
+
+		err := EmbedMonolithItemIdsInCreateItemRequests(ctx, "pl_test", responseItems, &requestItems)
+
+		require.NotNil(t, err)
+		require.Contains(t, err.Error(), "count mismatch")
+	})
+
+	t.Run("request_count_equal_to_effective_response_count", func(t *testing.T) {
+		// 2 request items, 3 response items (1 nil) = 2 effective
+		// Should pass because 2 == 2
+		responseItems := []models.PaymentPageItem{
+			{
+				ID: "ppi_aaaaaaaaaaaaaa",
+				Item: &models.Item{
+					ID:     "item_aaaaaaaaaaaa1a",
+					Name:   "Item1",
+					Amount: uint64Ptr(100),
+				},
+			},
+			{ID: "ppi_bbbbbbbbbbbbbb", Item: nil},
+			{
+				ID: "ppi_cccccccccccccc",
+				Item: &models.Item{
+					ID:     "item_cccccccccccc1c",
+					Name:   "Item2",
+					Amount: uint64Ptr(100),
+				},
+			},
+		}
+
+		name1 := "Item1"
+		name2 := "Item2"
+		requestItems := []nocode.MonolithPaymentPageItem{
+			{Item: &nocode.MonolithItem{Name: &name1, Amount: amountReqPtr(100)}},
+			{Item: &nocode.MonolithItem{Name: &name2, Amount: amountReqPtr(100)}},
+		}
+
+		err := EmbedMonolithItemIdsInCreateItemRequests(ctx, "pl_test", responseItems, &requestItems)
+
+		require.Nil(t, err, "request count == effective response count should pass")
+	})
+
+	t.Run("request_count_less_than_effective_response_errors_for_leftover", func(t *testing.T) {
+		// 1 request item, 3 response items (1 nil) = 2 effective
+		// Should ERROR because there are leftover unmatched response items
+		// The code requires ALL response items to be matched
+		responseItems := []models.PaymentPageItem{
+			{
+				ID: "ppi_dddddddddddddd",
+				Item: &models.Item{
+					ID:     "item_ddddddddddd1dd",
+					Name:   "Item1",
+					Amount: uint64Ptr(100),
+				},
+			},
+			{ID: "ppi_eeeeeeeeeeeeee", Item: nil},
+			{
+				ID: "ppi_ffffffffffffff",
+				Item: &models.Item{
+					ID:     "item_fffffffffff1ff",
+					Name:   "Item2",
+					Amount: uint64Ptr(100),
+				},
+			},
+		}
+
+		name1 := "Item1"
+		requestItems := []nocode.MonolithPaymentPageItem{
+			{Item: &nocode.MonolithItem{Name: &name1, Amount: amountReqPtr(100)}},
+		}
+
+		err := EmbedMonolithItemIdsInCreateItemRequests(ctx, "pl_test", responseItems, &requestItems)
+
+		// Expect error because Item2 in response has no matching request item
+		require.NotNil(t, err, "should error when there are unmatched response items")
+		require.Contains(t, err.Error(), "mismatched")
+	})
+}
