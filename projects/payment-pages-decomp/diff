+func TestGoalTracker_ValidationLogic(t *testing.T) {
+	t.Run("goal_end_timestamp in past with is_active=1 should be rejected", func(t *testing.T) {
+		// This tests the validation logic that should be applied in validateAndUpdateGoalTracker
+		pastTimestamp := time.Now().Unix() - 3600 // 1 hour ago
+		isActive := "1"
+
+		gt := &nocode.GoalTracker{
+			IsActive: &isActive,
+			MetaData: &nocode.GoalTrackerMetaData{
+				GoalEndTimestamp: &pkgDatatypes.NumericInt64Value{Value: pastTimestamp},
+			},
+		}
+
+		// Simulate the validation check from validateAndUpdateGoalTracker
+		shouldReject := false
+		if gt.IsActive != nil && *gt.IsActive == "1" {
+			if gt.MetaData != nil && gt.MetaData.GoalEndTimestamp != nil {
+				endsBy := gt.MetaData.GoalEndTimestamp.Value
+				if endsBy > 0 {
+					now := time.Now().Unix()
+					if now > endsBy {
+						shouldReject = true
+					}
+				}
+			}
+		}
+
+		assert.True(t, shouldReject, "Past timestamp with is_active=1 should be rejected")
+	})
+
+	t.Run("goal_end_timestamp in past with is_active=0 should be allowed", func(t *testing.T) {
+		pastTimestamp := time.Now().Unix() - 3600 // 1 hour ago
+		isActive := "0"
+
+		gt := &nocode.GoalTracker{
+			IsActive: &isActive,
+			MetaData: &nocode.GoalTrackerMetaData{
+				GoalEndTimestamp: &pkgDatatypes.NumericInt64Value{Value: pastTimestamp},
+			},
+		}
+
+		// Simulate the validation check
+		shouldReject := false
+		if gt.IsActive != nil && *gt.IsActive == "1" {
+			if gt.MetaData != nil && gt.MetaData.GoalEndTimestamp != nil {
+				endsBy := gt.MetaData.GoalEndTimestamp.Value
+				if endsBy > 0 {
+					now := time.Now().Unix()
+					if now > endsBy {
+						shouldReject = true
+					}
+				}
+			}
+		}
+
+		assert.False(t, shouldReject, "Past timestamp with is_active=0 should be allowed")
+	})
+
+	t.Run("goal_end_timestamp in future with is_active=1 should be allowed", func(t *testing.T) {
+		futureTimestamp := time.Now().Unix() + 7200 // 2 hours from now
+		isActive := "1"
+
+		gt := &nocode.GoalTracker{
+			IsActive: &isActive,
+			MetaData: &nocode.GoalTrackerMetaData{
+				GoalEndTimestamp: &pkgDatatypes.NumericInt64Value{Value: futureTimestamp},
+			},
+		}
+
+		// Simulate the validation check
+		shouldReject := false
+		if gt.IsActive != nil && *gt.IsActive == "1" {
+			if gt.MetaData != nil && gt.MetaData.GoalEndTimestamp != nil {
+				endsBy := gt.MetaData.GoalEndTimestamp.Value
