+package models
+
+import (
+	"testing"
+)
+
+func TestOrder_GetNotesAsMap(t *testing.T) {
+	t.Run("nil notes returns nil", func(t *testing.T) {
+		order := &Order{Notes: nil}
+		result := order.GetNotesAsMap()
+		if result != nil {
+			t.Errorf("expected nil, got %v", result)
+		}
+	})
+
+	t.Run("map notes returns map", func(t *testing.T) {
+		notes := map[string]interface{}{"key": "value"}
+		order := &Order{Notes: notes}
+		result := order.GetNotesAsMap()
+		if result == nil {
+			t.Error("expected map, got nil")
+		}
+		if result["key"] != "value" {
+			t.Errorf("expected 'value', got %v", result["key"])
+		}
+	})
+
+	t.Run("empty array returns nil (monolith format)", func(t *testing.T) {
+		// Monolith sends [] when notes are cleared
+		order := &Order{Notes: []interface{}{}}
+		result := order.GetNotesAsMap()
+		if result != nil {
+			t.Errorf("expected nil for empty array, got %v", result)
+		}
+	})
+
+	t.Run("non-empty array returns nil", func(t *testing.T) {
+		// Non-empty arrays should also return nil (defensive)
+		order := &Order{Notes: []interface{}{"item1", "item2"}}
+		result := order.GetNotesAsMap()
+		if result != nil {
+			t.Errorf("expected nil for non-empty array, got %v", result)
+		}
+	})
+
+	t.Run("other types return nil", func(t *testing.T) {
+		// Unexpected types should return nil
+		order := &Order{Notes: "string value"}
+		result := order.GetNotesAsMap()
+		if result != nil {
+			t.Errorf("expected nil for string, got %v", result)
+		}
+	})
+
+	t.Run("empty map returns empty map", func(t *testing.T) {
+		notes := map[string]interface{}{}
+		order := &Order{Notes: notes}
+		result := order.GetNotesAsMap()
+		if result == nil {
+			t.Error("expected empty map, got nil")
+		}
+		if len(result) != 0 {
+			t.Errorf("expected empty map, got %v", result)
+		}
+	})
+
+	t.Run("nested map in notes", func(t *testing.T) {
+		notes := map[string]interface{}{
+			"customer": map[string]interface{}{
+				"name":  "John",
+				"email": "john@test.com",
+			},
+			"order_id": "order_123",
+		}
+		order := &Order{Notes: notes}
+		result := order.GetNotesAsMap()
+		if result == nil {
+			t.Error("expected map, got nil")
+		}
+		if result["order_id"] != "order_123" {
+			t.Errorf("expected 'order_123', got %v", result["order_id"])
+		}
+	})
+}
