+			},
+			{
+				Item: &nocode.MonolithItem{
+					Name:   &name2,
+					Amount: amountReqPtr(200),
+				},
+			},
+		}
+
+		err := EmbedMonolithItemIdsInCreateItemRequests(ctx, "pl_test", responseItems, &requestItems)
+
+		require.Nil(t, err, "should match items correctly ignoring nil items")
+		require.NotNil(t, requestItems[0].StrippedMonolithPaymentPageItemId)
