+func TestEmbedMonolithItemIdsInCreateItemRequests_NilItems(t *testing.T) {
+	ctx := setupTestContext()
+
+	// Helper to create item Amount pointer for request (NumericUInt64Value for MonolithItem.Amount)
+	amountReqPtr := func(v uint64) *datatypes.NumericUInt64Value {
+		return &datatypes.NumericUInt64Value{Value: v}
+	}
+
+	t.Run("single_nil_item_in_response_skipped", func(t *testing.T) {
+		// Monolith returns 2 items, one with nil Item - should skip the nil one
+		// IDs must be exactly 14 alphanumeric chars after the prefix
+		responseItems := []models.PaymentPageItem{
+			{
+				ID: "ppi_12345678901234", // Exactly 14 chars
+				Item: &models.Item{
+					ID:     "item_abcdef12345678", // Exactly 14 chars
+					Name:   "Valid Item",
+					Amount: uint64Ptr(100),
+				},
+			},
+			{
+				ID:   "ppi_09876543210987", // Exactly 14 chars for nil item
+				Item: nil,                  // Item is nil - will be skipped
+			},
+		}
+
+		name := "Valid Item"
+		requestItems := []nocode.MonolithPaymentPageItem{
+			{
+				Item: &nocode.MonolithItem{
+					Name:   &name,
+					Amount: amountReqPtr(100),
+				},
+			},
+		}
+
+		err := EmbedMonolithItemIdsInCreateItemRequests(ctx, "pl_test", responseItems, &requestItems)
+
+		require.Nil(t, err, "should handle nil Item in response by skipping")
+		require.NotNil(t, requestItems[0].StrippedMonolithPaymentPageItemId, "valid item should have ID embedded")
+	})
+
+	t.Run("all_items_nil_causes_count_mismatch", func(t *testing.T) {
+		// If all response items have nil Item, and we have request items, should error
+		responseItems := []models.PaymentPageItem{
+			{ID: "ppi_11111111111111", Item: nil},
+			{ID: "ppi_22222222222222", Item: nil},
+		}
+
+		name := "Test Item"
+		requestItems := []nocode.MonolithPaymentPageItem{
+			{
+				Item: &nocode.MonolithItem{
+					Name:   &name,
+					Amount: amountReqPtr(100),
+				},
+			},
+		}
+
+		err := EmbedMonolithItemIdsInCreateItemRequests(ctx, "pl_test", responseItems, &requestItems)
