+// extractErrorDescriptionFromNCAResponse extracts the error description from NCA response
+// NCA error format: {"error": {"code": "...", "description": "...", ...}}
+func extractErrorDescriptionFromNCAResponse(ncaResponse response.IResponse) string {
+	if ncaResponse.StatusCode() == 200 {
+		return ""
+	}
+
+	// Try to get error from response.Error() first (preferred)
+	if ncaResponse.Error() != nil {
+		ncaErr := ncaResponse.Error()
+		if ncaErr.GetNCAError() != nil {
+			desc := ncaErr.GetNCAError().Error()
+			return truncateErrorMessage(desc)
+		}
+		return truncateErrorMessage(ncaErr.Message())
+	}
