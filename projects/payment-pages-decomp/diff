+func extractDescriptionFromErrorMap(bodyMap map[string]interface{}) string {
+	errorObj, exists := bodyMap["error"]
+	if !exists {
+		return "unknown_error"
+	}
+
+	errorMap, ok := errorObj.(map[string]interface{})
+	if !ok {
+		return "unknown_error"
+	}
+
